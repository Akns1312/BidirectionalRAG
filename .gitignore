__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# HuggingFace model cache — large, re-downloaded on deploy
.cache/

# Egg info
*.egg-info/
dist/
build/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Test cache
.pytest_cache/
.coverage